<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_pawn_dashboard_form" model="ir.ui.view">
        <field name="name">pawn.dashboard.form</field>
        <field name="model">pawn.dashboard</field>
        <field name="arch" type="xml">
            <form string="Pawn Dashboard" delete="0">
                <header>
                    <button name="action_refresh" type="object" string="Refresh" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="company_id"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                    </group>

                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_contracts" type="object" class="oe_stat_button" icon="fa-folder-open">
                            <field name="total_contracts" widget="statinfo" string="Contracts"/>
                        </button>
                        <button name="action_open_active_contracts" type="object" class="oe_stat_button" icon="fa-check-circle">
                            <field name="active_contracts" widget="statinfo" string="Active"/>
                        </button>
                        <button name="action_open_overdue_contracts" type="object" class="oe_stat_button" icon="fa-exclamation-triangle">
                            <field name="overdue_contracts" widget="statinfo" string="Overdue"/>
                        </button>
                        <button name="action_open_forfeited_contracts" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="forfeited_contracts" widget="statinfo" string="Forfeited"/>
                        </button>
                        <button name="action_open_payments" type="object" class="oe_stat_button" icon="fa-money">
                            <field name="total_collection" widget="statinfo" string="Collections"/>
                        </button>
                    </div>

                    <group string="Financial KPIs">
                        <group>
                            <field name="total_principal_disbursed" readonly="1"/>
                            <field name="total_outstanding_principal" readonly="1"/>
                        </group>
                        <group>
                            <field name="total_interest_collected" readonly="1"/>
                            <field name="total_penalty_collected" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pawn_dashboard_client" model="ir.actions.client">
        <field name="name">Dashboard</field>
        <field name="tag">pawn_dashboard</field>
    </record>
</odoo>
